---
import "../styles/global.css";

type Props = {
  title?: string;
};

const { title = "Das Vegane Quartett Rating" } = Astro.props;
---

<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" />
  </head>

  <body>
    <header class="site-header">
      <a href="/" class="brand">
        <img src="/logo.png" alt="Das Vegane Quartett" />
        <span>Quartett Rating</span>
      </a>

      <nav>
        <a href="/bewerten">Bewerten</a>
        <a href="/admin">Admin</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>
  </body>
</html>