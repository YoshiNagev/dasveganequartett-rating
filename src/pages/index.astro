---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Das Vegane Quartett Rating">
  <section class="home-hero">
    <div class="home-card">
      <p class="eyebrow">Community-Rating</p>

      <h1>Bewerte die Argumente des Veganen Quartetts</h1>

      <p class="hero-text">
        Hilf dabei, die finalen Kartenwerte festzulegen.
        Du bewertest 54 Argumente nach 6 Kategorien.
      </p>

      <div class="hero-facts">
        <span>54 Argumente</span>
        <span>6 Skalen</span>
        <span>ca. 10 Minuten</span>
      </div>

      <a class="button" href="/bewerten">
        Bewertung starten
      </a>
    </div>
  </section>
</BaseLayout>